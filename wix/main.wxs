<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
    Id="*"
    Name="Pin"
    Language="1033"
    Version="$(var.Version)"
    Manufacturer="sqhh99"
    UpgradeCode="B7F50808-6DBC-48A6-8295-282FB407E038">

    <Package
      InstallerVersion="500"
      Compressed="yes"
      InstallScope="perUser"
      InstallPrivileges="limited" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of Pin is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Icon Id="PinIcon" SourceFile="resource\icon\pin.ico" />
    <Property Id="ARPPRODUCTICON" Value="PinIcon" />
    <Property Id="ARPNOREPAIR" Value="yes" Secure="yes" />
    <Property Id="ARPNOMODIFY" Value="yes" Secure="yes" />
    <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="wix\License.rtf" />

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="LocalAppDataFolder">
        <Directory Id="LocalProgramsFolder" Name="Programs">
          <Directory Id="INSTALLFOLDER" Name="Pin" />
        </Directory>
      </Directory>
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="Pin" />
      </Directory>
    </Directory>

    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="PinExecutable" Guid="C9A91AA0-7B5E-47C2-A51F-A994C61979C7">
        <RegistryKey Root="HKCU" Key="Software\sqhh99\Pin">
          <RegistryValue Name="installed" Type="integer" Value="1" KeyPath="yes" />
          <RegistryValue Name="InstallDir" Type="string" Value="[INSTALLFOLDER]" />
          <RegistryValue Name="Version" Type="string" Value="$(var.Version)" />
        </RegistryKey>
        <File Id="PinExe" Source="$(var.CargoTargetBinDir)\pin.exe" />
        <Shortcut
          Id="ApplicationStartMenuShortcut"
          Directory="ApplicationProgramsFolder"
          Name="Pin"
          Description="Pin windows on top"
          Target="[INSTALLFOLDER]pin.exe"
          WorkingDirectory="INSTALLFOLDER"
          Icon="PinIcon" />
        <RemoveFolder Id="RemoveInstallFolder" Directory="INSTALLFOLDER" On="uninstall" />
        <RemoveFolder Id="RemoveLocalProgramsFolder" Directory="LocalProgramsFolder" On="uninstall" />
        <RemoveFolder Id="RemoveApplicationProgramsFolder" Directory="ApplicationProgramsFolder" On="uninstall" />
      </Component>
    </DirectoryRef>

    <Feature Id="DefaultFeature" Title="Pin" Level="1">
      <ComponentRef Id="PinExecutable" />
    </Feature>

    <UIRef Id="WixUI_InstallDir" />
    <UIRef Id="WixUI_ErrorProgressText" />
  </Product>
</Wix>
